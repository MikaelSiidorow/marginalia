# Database (PostgreSQL with wal_level=logical required for Zero replication)
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"
ZERO_UPSTREAM_DB="postgres://root:mysecretpassword@localhost:5432/local"

# Zero Cache Configuration
ZERO_REPLICA_FILE="/tmp/marginalia-sync-replica.db"
ZERO_MUTATE_URL="http://localhost:5173/api/zero/mutate"
ZERO_QUERY_URL="http://localhost:5173/api/zero/get-queries"
PUBLIC_SERVER="http://localhost:4848"
ZERO_QUERY_FORWARD_COOKIES=true
ZERO_MUTATE_FORWARD_COOKIES=true

# better-auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-generate-a-real-secret"
BETTER_AUTH_URL="http://localhost:5173"

# GitHub OAuth (for repo access)
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:5173/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# SMTP (Scaleway Transactional Email - https://www.scaleway.com/en/transactional-email-tem/)
# Create API keys at: https://console.scaleway.com/iam/api-keys
# SMTP_HOST=smtp.tem.scw.cloud
# SMTP_PORT=587
# SMTP_USER=<your-project-id>
# SMTP_PASS=<your-secret-key>
# SMTP_FROM=noreply@yourdomain.com

# Production-only
# ZERO_ADMIN_PASSWORD=change-me-generate-a-real-password
# POSTGRES_PASSWORD=change-me-generate-a-real-password
