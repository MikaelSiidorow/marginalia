{
  "name": "marginalia",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "docker compose up -d --wait && concurrently --names app,zero \"vite dev\" \"zero-cache-dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "drizzle-zero generate --output src/lib/zero/zero-schema.gen.ts && (svelte-kit sync || echo '')",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev:app": "vite dev",
    "dev:zero": "zero-cache-dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "docker compose up -d --wait",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "docker compose up -d --wait && drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/lib/server/db/seed.ts",
    "zero:generate": "drizzle-zero generate --output src/lib/zero/zero-schema.gen.ts",
    "zero:start": "zero-cache-dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:css": "stylelint \"src/**/*.{css,svelte}\"",
    "i18n:extract": "lingui extract",
    "i18n:extract:watch": "lingui extract --watch"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^0.2.1",
    "concurrently": "^9.2.1",
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.2",
    "@types/nodemailer": "^7.0.9",
    "drizzle-kit": "^0.31.8",
    "drizzle-zero": "^0.17.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@testcontainers/postgresql": "^11.11.0",
    "stylelint": "^17.1.1",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "@lingui/cli": "^5.9.0",
    "@lingui/conf": "^5.9.0",
    "@sveltejs/adapter-node": "^5.5.2"
  },
  "dependencies": {
    "@mikstack/email": "^0.1.2",
    "@mikstack/form": "^0.1.0",
    "@mikstack/notifications": "^0.1.1",
    "@rocicorp/zero": "^0.25.12",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "nodemailer": "^8.0.1",
    "postgres": "^3.4.8",
    "valibot": "^1.2.0",
    "zero-svelte": "^1.2.2",
    "phosphor-svelte": "^3.1.0",
    "svelte-sonner": "^1.0.0",
    "@lingui/core": "^5.9.0",
    "@mikstack/svelte-lingui": "^0.1.4"
  },
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3"
  ]
}
