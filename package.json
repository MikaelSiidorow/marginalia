{
  "name": "marginalia",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "docker compose up -d --wait && concurrently --names app,zero \"vite dev\" \"zero-cache-dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "drizzle-zero generate --output src/lib/zero/zero-schema.gen.ts && (svelte-kit sync || echo '')",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev:app": "vite dev",
    "dev:zero": "zero-cache-dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "docker compose up -d --wait",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "docker compose up -d --wait && drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/lib/server/db/seed.ts",
    "zero:generate": "drizzle-zero generate --output src/lib/zero/zero-schema.gen.ts",
    "zero:start": "zero-cache-dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:css": "stylelint \"src/**/*.{css,svelte}\"",
    "i18n:extract": "lingui extract",
    "i18n:extract:watch": "lingui extract --watch"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.2",
    "@lingui/cli": "^5.9.0",
    "@lingui/conf": "^5.9.0",
    "@sveltejs/adapter-node": "^5.5.2",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/nodemailer": "^7.0.9",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-zero": "^0.17.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "stylelint": "^17.1.1",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^0.2.1",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@kubiks/otel-drizzle": "^2.1.0",
    "@lingui/core": "^5.9.0",
    "@mikstack/email": "^0.1.2",
    "@mikstack/form": "^0.1.0",
    "@mikstack/notifications": "^0.1.1",
    "@mikstack/svelte-lingui": "^0.1.4",
    "@myriaddreamin/typst-ts-node-compiler": "^0.7.0-rc2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.212.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/context-zone": "^2.5.1",
    "@opentelemetry/core": "^2.5.1",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.212.0",
    "@opentelemetry/instrumentation": "^0.212.0",
    "@opentelemetry/instrumentation-document-load": "^0.57.0",
    "@opentelemetry/instrumentation-fetch": "^0.212.0",
    "@opentelemetry/instrumentation-pino": "^0.58.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-logs": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-web": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@rocicorp/zero": "^0.25.12",
    "better-auth": "^1.4.18",
    "codemirror-lang-typst": "^0.4.0",
    "drizzle-orm": "^0.45.1",
    "import-in-the-middle": "^3.0.0",
    "nodemailer": "^8.0.1",
    "pdfjs-dist": "^5.4.624",
    "phosphor-svelte": "^3.1.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "svelte-sonner": "^1.0.0",
    "valibot": "^1.2.0",
    "ws": "^8.19.0",
    "zero-svelte": "^1.2.2"
  },
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3"
  ]
}
